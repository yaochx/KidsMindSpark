# Copy this file to .env for local backend configuration.
# Never commit real API keys.

STORY_PROVIDER=deepseek
DEEPSEEK_API_KEY=<your_deepseek_api_key>
DEEPSEEK_STORY_MODEL=deepseek-v4-flash

IMAGE_PROVIDER=mock

# Optional OpenAI story provider
OPENAI_API_KEY=<your_openai_api_key>
OPENAI_STORY_MODEL=gpt-4o-mini

# Optional OpenAI image provider
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1024

# Optional local data directory
MINDSPARK_DATA_DIR=backend/data
